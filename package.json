{
  "name": "conjugame-ultimate",
  "description": "Conjugame - verb conjugation quiz game monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "android": "expo run:android",
    "prebuild": "nps prebuild",
    "build": "nps build",
    "dev": "turbo run dev --parallel --force",
    "eslint": "eslint \"**/*.+(js|jsx|ts|tsx)\"",
    "eslint:fix": "eslint --fix \"**/*.+(js|jsx|ts|tsx)\"",
    "preinstall": "npx only-allow pnpm",
    "ios": "expo run:ios",
    "migrate": "make -C apps/database migrateup",
    "migrate:down": "make -C apps/database migratedown",
    "native": "cd apps/expo && pnpm start",
    "precommit": "nps precommit",
    "prepare": "npx husky install",
    "prettier": "prettier --check \"**/*.+(js|jsx|ts|tsx|json|yml|yaml|md|css)\"",
    "prettier:fix": "prettier --write \"**/*.+(js|jsx|ts|tsx|json|yml|yaml|md|css)\"",
    "web": "cd apps/next && pnpm next"
  },
  "lint-staged": {
    "./*/**/*.{js,jsx,ts,tsx}": [
      "pnpm run prettier:fix",
      "pnpm run eslint:fix"
    ],
    "*.{json,md}": [
      "pnpm run prettier:fix"
    ]
  },
  "resolutions": {
    "metro": "~0.76.7",
    "metro-resolver": "~0.76.7"
  },
  "dependencies": {
    "@react-navigation/bottom-tabs": "^6.6.1",
    "@react-navigation/elements": "^1.3.31",
    "@react-navigation/native-stack": "^6.11.0",
    "@types/pg": "8.10.9",
    "expo": "~49.0.18",
    "expo-splash-screen": "~0.20.5",
    "expo-status-bar": "~1.6.0",
    "husky": "8.0.3",
    "react": "18.2.0"
  },
  "devDependencies": {
    "@babel/core": "7.23.7",
    "@eslint/js": "9.20.0",
    "@jarrodmedrano/claude-skills": "1.0.16",
    "@types/react": "18.2.25",
    "@types/react-native": "0.72.2",
    "@typescript-eslint/eslint-plugin": "8.56.1",
    "@typescript-eslint/parser": "8.56.1",
    "@vitejs/plugin-react": "5.1.4",
    "@vitest/coverage-istanbul": "4.0.18",
    "@vitest/ui": "4.0.18",
    "eslint": "9.20.1",
    "jsdom": "20.0.3",
    "nps": "5.10.0",
    "prettier": "3.0.3",
    "prettier-plugin-tailwindcss": "0.6.9",
    "turbo": "2.4.0",
    "typescript": "5.2.2",
    "vite": "7.3.1",
    "vite-plugin-istanbul": "4.0.0",
    "vitest": "4.0.18"
  },
  "peerDependencies": {
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-native": "0.72.4",
    "react-native-gesture-handler": "2.12.0",
    "react-native-reanimated": "3.3.0",
    "react-native-safe-area-context": "4.6.3",
    "react-native-screens": "3.22.0",
